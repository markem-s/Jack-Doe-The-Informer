# ── OpenAI ────────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ── Slack ──────────────────────────────────────────────────
# Bot token (starts with xoxb-)
SLACK_BOT_TOKEN=xoxb-...

# Target channel ID (not name) — e.g. C08XXXXXXX
# Right-click the channel in Slack → "Copy link" → ID is the last segment
SLACK_CHANNEL_ID=C0XXXXXXXXX
